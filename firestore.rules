rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function campaignData(campaignId) {
      return get(/databases/$(database)/documents/campaigns/$(campaignId)).data;
    }

    function isCampaignDM(campaignId) {
      return campaignId != null && campaignData(campaignId).dmUid == request.auth.uid;
    }

    function isCampaignMember(campaignId) {
      return campaignId != null && request.auth.uid in campaignData(campaignId).memberUids;
    }

    match /characters/{characterId} {
      // Leer: el dueño, o cualquier miembro de la campaña del personaje
      allow read: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid ||
         isCampaignMember(resource.data.campaignId));

      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;

      // Editar: el dueño, o el máster de su campaña (daño en combate, ajustes
      // de mesa). Los compañeros de campaña solo pueden sumar PX (reparto de
      // experiencia al saquear una sala).
      allow update: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid ||
         isCampaignDM(resource.data.campaignId) ||
         (isCampaignMember(resource.data.campaignId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['xp', 'updatedAt']) &&
          request.resource.data.xp >= resource.data.xp &&
          // Un saqueo razonable: nadie puede regalar niveles de golpe
          request.resource.data.xp <= resource.data.xp + 50000));

      // Borrar: solo el dueño
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      match /notes/{noteId} {
        function characterData() {
          return get(/databases/$(database)/documents/characters/$(characterId)).data;
        }

        // El máster de la campaña gestiona las notas; el dueño del personaje
        // solo puede leer las marcadas como compartidas.
        allow read: if signedIn() &&
          (isCampaignDM(characterData().campaignId) ||
           (characterData().ownerUid == request.auth.uid &&
            resource.data.visibility == 'shared'));

        allow create, update, delete: if signedIn() &&
          isCampaignDM(characterData().campaignId);
      }
    }

    // Códigos de invitación: resuelven código → campaña sin exponer nada más
    match /invites/{code} {
      // Lectura puntual del código exacto; el listado queda prohibido
      allow get: if signedIn();
      allow list: if false;

      // Solo el máster de la campaña referida puede publicar o retirar su código
      allow create, update: if signedIn() &&
        request.resource.data.keys().hasOnly(['campaignId']) &&
        get(/databases/$(database)/documents/campaigns/$(request.resource.data.campaignId))
          .data.dmUid == request.auth.uid;
      allow delete: if signedIn() &&
        get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId))
          .data.dmUid == request.auth.uid;
    }

    match /campaigns/{campaignId} {
      // Privadas: solo el máster y los miembros pueden leer la campaña
      allow read: if signedIn() &&
        (resource.data.dmUid == request.auth.uid ||
         request.auth.uid in resource.data.memberUids);

      allow create: if signedIn() &&
        request.resource.data.dmUid == request.auth.uid &&
        request.auth.uid in request.resource.data.memberUids;

      // El DM puede editar todo; los miembros pueden mover fichas del tablero;
      // otros usuarios solo pueden añadirse a memberUids (unirse por código)
      allow update: if signedIn() &&
        (resource.data.dmUid == request.auth.uid ||
         (request.auth.uid in resource.data.memberUids &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['tokens', 'boardLog', 'revealedRooms', 'openDoors']) &&
          // Topes de tamaño: un miembro no puede inflar el documento
          (!request.resource.data.keys().hasAny(['boardLog']) ||
           request.resource.data.boardLog.size() <= 60) &&
          (!request.resource.data.keys().hasAny(['tokens']) ||
           request.resource.data.tokens.size() <= 60) &&
          (!request.resource.data.keys().hasAny(['openDoors']) ||
           request.resource.data.openDoors.size() <= 2000) &&
          (!request.resource.data.keys().hasAny(['revealedRooms']) ||
           request.resource.data.revealedRooms.size() <= 500)) ||
         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']) &&
          request.resource.data.memberUids.hasAll(resource.data.memberUids) &&
          request.auth.uid in request.resource.data.memberUids));

      allow delete: if signedIn() && resource.data.dmUid == request.auth.uid;

      // Handouts: el máster gestiona; los jugadores solo leen los revelados
      // (sus consultas deben filtrar por revealed == true)
      match /handouts/{handoutId} {
        allow read: if signedIn() &&
          (isCampaignDM(campaignId) ||
           (isCampaignMember(campaignId) && resource.data.revealed == true));

        allow create, update, delete: if signedIn() && isCampaignDM(campaignId);
      }
    }
  }
}
